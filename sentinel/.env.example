# ── HuggingFace (Model Access) ─────────────────────────────────────────────
# 1. Get your token at https://huggingface.co/settings/tokens
# 2. Ensure you have accepted the "Llama-3.2-1B-Instruct" terms on the HuggingFace model card.
HF_TOKEN=your_huggingface_token_here

# ── Lydian Engine: Core Logic ──────────────────────────────────────────────

# Mode: 'local' (Runs on your CPU, 100% private) or 'cloud' (Uses HuggingFace API, very fast).
SENTINEL_INFERENCE_MODE=local

# Which SLM model to use for classification. Llama-3.2-1B is the default for high-speed triage.
SENTINEL_FILTER_MODEL_ID=meta-llama/Llama-3.2-1B-Instruct

# ── Modular Intelligence Thresholds (Fine-Tuning) ──────────────────────────
# These parameters control the "RAG-First" brain of the engine.

# AUTO-NOISE: If a news item's similarity to history is lower than this score (0.0 to 1.0), 
# and it doesn't contain high-alert keywords, it is auto-classified as "Noise" to save CPU.
SENTINEL_SHORT_CIRCUIT_NOISE_THRESHOLD=0.15

# AUTO-CRITICAL: If a news item is VERY similar to a known historical disaster/event 
# (score above this threshold), it is flagged as "Critical" instantly without calling the SLM.
SENTINEL_SHORT_CIRCUIT_CRITICAL_THRESHOLD=0.92

# BLACK SWAN DETECTION: If the model flags news as "Critical" but its similarity to past 
# events is LOWER than this score, we label it as a "Black Swan" (a novel/unprecedented event).
SENTINEL_BLACK_SWAN_THRESHOLD=0.50

# ── Retrieval (RAG) Settings ───────────────────────────────────────────────
SENTINEL_LANCEDB_TABLE_NAME=market_history
SENTINEL_EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
SENTINEL_EMBEDDING_DIM=384
SENTINEL_RAG_TOP_K=3

# ── Performance & SLAs ─────────────────────────────────────────────────────
# Maximum time (in milliseconds) the SLM is allowed to think before we default to "Noise".
SENTINEL_FILTER_TIMEOUT_MS=150
# Maximum length of reasoning the SLM can provide.
SENTINEL_FILTER_MAX_NEW_TOKENS=128

SENTINEL_API_HOST=0.0.0.0
SENTINEL_API_PORT=8000
# Total target time for the entire pipeline.
SENTINEL_REQUEST_TIMEOUT_MS=200

# ── Ingestion Service (Go Microservice) ────────────────────────────────────
# 'mock' reads from a file; 'rss' polls real feeds; 'api' waits for a real network feed.
FEED_MODE=mock
MOCK_FILE=testdata/mock_news_feed.json
MOCK_INTERVAL=500ms

# RSS Settings (only used if FEED_MODE=rss)
# Example: https://finance.yahoo.com/rss/topstories,https://search.cnbc.com/rs/search/combinedcms/view.xml?partnerId=401&id=100003114
RSS_URLS=
RSS_INTERVAL=5m

TARGET_URL=http://localhost:8000/ingest
BUFFER_CAPACITY=256
LOG_LEVEL=info
