# Environment variable template for local development.
# Copy this to .env and fill in your values.
# DO NOT commit the .env file to version control.

# ── HuggingFace (required for gated models like Llama-3) ─────────────────────
HF_TOKEN=hf_your_token_here

# ── Sentinel Python service ───────────────────────────────────────────────────
SENTINEL_LANCEDB_PATH=./data/lancedb
SENTINEL_LANCEDB_TABLE_NAME=market_history
SENTINEL_MARKET_HISTORY_CSV=./data/market_history.csv
SENTINEL_EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
SENTINEL_EMBEDDING_DIM=384
SENTINEL_RAG_TOP_K=3
SENTINEL_FILTER_MODEL_ID=meta-llama/Llama-3.2-1B-Instruct
SENTINEL_FILTER_MAX_NEW_TOKENS=128
SENTINEL_FILTER_TIMEOUT_MS=150
SENTINEL_API_HOST=0.0.0.0
SENTINEL_API_PORT=8000
SENTINEL_REQUEST_TIMEOUT_MS=200
SENTINEL_HF_CACHE_DIR=./data/models

# ── Go ingestion service ──────────────────────────────────────────────────────
FEED_MODE=mock
MOCK_FILE=testdata/mock_news_feed.json
MOCK_INTERVAL=500ms
TARGET_URL=http://localhost:8000/ingest
BUFFER_CAPACITY=256
LOG_LEVEL=info
